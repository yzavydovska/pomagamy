# Skopiuj do pliku `.env` w folderze `mobile` i uzupełnij wartości z Firebase Console
# → Project settings → Your apps → SDK setup (Web).
# Po zmianach: npx expo start --clear
#
# Firestore: włącz Email/hasło w Authentication, utwórz bazę Firestore, wklej reguły z firestore.rules.
# Przy pierwszym zapytaniu o zgłoszenia może być potrzebny indeks złożony — link poda Firebase w błędzie.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Opcjonalnie: numer telefonu do zgłaszania skarg / infolinia (widoczny na ekranie „Zgłoś skargę”).
# Przykład: EXPO_PUBLIC_COMPLAINTS_PHONE="+48 22 123 45 67"

EXPO_PUBLIC_COMPLAINTS_PHONE=
